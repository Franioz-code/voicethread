# --- VoiceThread environment --------------------------------------------------
# 1. Get a FREE API key at https://elevenlabs.io
#    Sign in -> click your name (bottom-left) -> "API Keys" -> "Create API Key".
# 2. Copy this file to ".env"  (cp .env.example .env)  and paste your key below.
# 3. Restart the server.  (You can also set ELEVENLABS_API_KEY as a real
#    environment variable instead of using this file — either works.)

ELEVENLABS_API_KEY=your_api_key_here

# Optional: change the port the server runs on (default 3000).
# PORT=3000
